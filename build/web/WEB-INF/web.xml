        <url-pattern>/ItemController</url-pattern>
    </servlet-mapping>
     <servlet-mapping>
        <servlet-name>SupplierController</servlet-name>
        <url-pattern>/SupplierController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PurchaseOrderController</servlet-name>
        <url-pattern>/PurchaseOrderController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>BomController</servlet-name>
