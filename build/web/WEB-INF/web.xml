<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.0" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">

    <!-- ==================== LISTENERS ==================== -->
    <!-- Khoi dong multi-tenant: register default + load active tenants tu DB -->
    <listener>
        <listener-class>pms.listener.TenantBootstrapListener</listener-class>
    </listener>

    <!-- ==================== FILTER ==================== -->
    <!-- Character Encoding Filter - Bat buoc UTF-8 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>pms.filter.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Authentication Filter - Bắt buộc đăng nhập mới vào được trang -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>pms.filter.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Payment Status Auto-Check Filter -->
    <filter>
        <filter-name>PaymentStatusFilter</filter-name>
        <filter-class>pms.filter.PaymentStatusFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>PaymentStatusFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Tenant Context Filter - Set tenant cho moi request -->
    <filter>
        <filter-name>TenantFilter</filter-name>
        <filter-class>pms.filter.TenantFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>TenantFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== SERVLETS ==================== -->
    <servlet>
        <servlet-name>MainController</servlet-name>
        <servlet-class>pms.controllers.MainController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserController</servlet-name>
        <servlet-class>pms.controllers.UserController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>BillController</servlet-name>
        <servlet-class>pms.controllers.BillController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CustomerController</servlet-name>
        <servlet-class>pms.controllers.CustomerController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>WorkOrderController</servlet-name>
        <servlet-class>pms.controllers.WorkOrderController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProductionLogController</servlet-name>
        <servlet-class>pms.controllers.ProductionLogController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>BOMController</servlet-name>
        <servlet-class>pms.controllers.BOMController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ItemController</servlet-name>
        <servlet-class>pms.controllers.ItemController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PaymentController</servlet-name>
        <servlet-class>pms.controllers.PaymentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FileController</servlet-name>
        <servlet-class>pms.controllers.FileController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DefectController</servlet-name>
        <servlet-class>pms.controllers.DefectController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PurchaseOrderController</servlet-name>
        <servlet-class>pms.controllers.PurchaseOrderController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SupplierController</servlet-name>
        <servlet-class>pms.controllers.SupplierController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoutingController</servlet-name>
        <servlet-class>pms.controllers.RoutingController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoutingStepController</servlet-name>
        <servlet-class>pms.controllers.RoutingStepController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardController</servlet-name>
        <servlet-class>pms.controllers.DashboardController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AutoCompleteSearchServlet</servlet-name>
        <servlet-class>pms.controllers.AutoCompleteSearchServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ExportController</servlet-name>
        <servlet-class>pms.controllers.ExportController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>NotificationServlet</servlet-name>
        <servlet-class>pms.controllers.NotificationServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>InventoryController</servlet-name>
        <servlet-class>pms.controllers.InventoryController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>QcController</servlet-name>
        <servlet-class>pms.controllers.QcController</servlet-class>
    </servlet>
    <servlet>
