    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CustomerController</servlet-name>
        <url-pattern>/CustomerController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>WorkOrderController</servlet-name>
        <url-pattern>/WorkOrderController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
