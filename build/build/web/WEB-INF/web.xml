<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">
    <servlet>
        <servlet-name>BOMServlet</servlet-name>
        <servlet-class>controller.BOMServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DefectReasonServlet</servlet-name>
        <servlet-class>controller.DefectReasonServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoutingServlet</servlet-name>
        <servlet-class>controller.RoutingServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoutingStepServlet</servlet-name>
        <servlet-class>controller.RoutingStepServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>listRoutingStep</servlet-name>
        <servlet-class>listRoutingStep</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BOMServlet</servlet-name>
        <url-pattern>/BOMServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DefectReasonServlet</servlet-name>
        <url-pattern>/DefectReasonServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RoutingServlet</servlet-name>
        <url-pattern>/RoutingServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RoutingStepServlet</servlet-name>
        <url-pattern>/RoutingStepServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>listRoutingStep</servlet-name>
        <url-pattern>/listRoutingStep</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>BOMServlet</welcome-file>
    </welcome-file-list>
</web-app>
